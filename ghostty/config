# style
font-size = 16

config-file = "?~/.cache/alzeck/theme/ghostty.conf"
# background/opacity are managed by ~/.config/ghostty/bin/theme-toggle
background-blur-radius = 200

title = " "
macos-titlebar-style = transparent

# tmux + zsh 
shell-integration = zsh
command = "/opt/homebrew/bin/tmux new -As0"
initial-command = "/opt/homebrew/bin/tmux new -As0"

# Remove tabs and windows keybindings
keybind = cmd+t=unbind
keybind = cmd+n=unbind
keybind = cmd+d=unbind
keybind = cmd+shift+d=unbind
keybind = cmd+shift+l=text:\x02T
keybind = chain=reload_config

macos-option-as-alt = left

mouse-hide-while-typing = false
copy-on-select = true
confirm-close-surface = false
link-url = true

window-colorspace = display-p3
