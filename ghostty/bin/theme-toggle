#!/usr/bin/env zsh

set -euo pipefail

cache_dir="${HOME}/.cache/alzeck/theme"
mode_file="${cache_dir}/mode"
tmux_theme_file="${cache_dir}/tmux.conf"
ghostty_theme_file="${cache_dir}/ghostty.conf"
tmux_config="${HOME}/.config/tmux/tmux.conf"
tmux_catppuccin_plugin="${HOME}/.tmux/plugins/tmux/catppuccin.tmux"

mkdir -p "${cache_dir}"

read_mode() {
  if [[ -f "${mode_file}" ]]; then
    local mode
    mode="$(<"${mode_file}")"
    mode="${mode//$'\n'/}"
    if [[ "${mode}" == "dark" || "${mode}" == "light" ]]; then
      print -r -- "${mode}"
      return
    fi
  fi

  print -r -- "dark"
}

target_mode=""
case "${1:-toggle}" in
  toggle)
    if [[ "$(read_mode)" == "dark" ]]; then
      target_mode="light"
    else
      target_mode="dark"
    fi
    ;;
  dark|light)
    target_mode="${1}"
    ;;
  status)
    read_mode
    exit 0
    ;;
  *)
    print -u2 "usage: theme-toggle [toggle|dark|light|status]"
    exit 1
    ;;
esac

tmux_flavor="mocha"
ghostty_theme="Catppuccin Mocha"
ghostty_background_opacity="0.65"
ghostty_background="000000"

if [[ "${target_mode}" == "light" ]]; then
  tmux_flavor="latte"
  ghostty_theme="Catppuccin Latte"
  ghostty_background_opacity="0.9"
  ghostty_background=""
fi

cat > "${mode_file}" <<EOF
${target_mode}
EOF

cat > "${tmux_theme_file}" <<EOF
# Generated by ~/.config/ghostty/bin/theme-toggle
set -g @catppuccin_flavor "${tmux_flavor}"
EOF

{
  cat <<EOF
# Generated by ~/.config/ghostty/bin/theme-toggle
theme = "${ghostty_theme}"
background-opacity = ${ghostty_background_opacity}
EOF
  if [[ -n "${ghostty_background}" ]]; then
    cat <<EOF
background = ${ghostty_background}
EOF
  else
    cat <<EOF
# background intentionally unset (use theme default)
EOF
  fi
} > "${ghostty_theme_file}"

if command -v tmux >/dev/null 2>&1 && tmux list-sessions >/dev/null 2>&1; then
  while IFS= read -r opt; do
    tmux set-option -gu "${opt}" >/dev/null 2>&1 || true
  done < <(tmux show-options -g 2>/dev/null | awk '$1 ~ /^@thm_/ { print $1 }')

  tmux set-option -g @catppuccin_flavor "${tmux_flavor}" >/dev/null 2>&1 || true

  if [[ -f "${tmux_catppuccin_plugin}" ]]; then
    tmux source-file "${tmux_catppuccin_plugin}" >/dev/null 2>&1 || true
  fi

  tmux source-file "${tmux_config}" >/dev/null 2>&1 || true
  tmux refresh-client -S >/dev/null 2>&1 || true
  tmux display-message "theme: ${target_mode}" >/dev/null 2>&1 || true
fi

